# .gitattributes
# Force UTF-8 + LF line endings across the repo
# Prevents Windows + GBK + PowerShell encoding issues
# Reference: https://git-scm.com/docs/gitattributes

# Default for all text files: UTF-8 + LF
* text=auto eol=lf

# Markdown - force UTF-8
*.md text eol=lf encoding=utf-8
*.markdown text eol=lf encoding=utf-8

# Code files - force UTF-8
*.py text eol=lf encoding=utf-8
*.ps1 text eol=lf encoding=utf-8
*.sh text eol=lf encoding=utf-8
*.json text eol=lf encoding=utf-8
*.yml text eol=lf encoding=utf-8
*.yaml text eol=lf encoding=utf-8
*.toml text eol=lf encoding=utf-8
*.txt text eol=lf encoding=utf-8

# Shell scripts must be LF (not CRLF)
*.sh text eol=lf
*.bash text eol=lf

# Binary files (no encoding conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Lock files should be LF for cross-platform consistency
*.lock text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf
